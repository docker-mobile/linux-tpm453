pkgname = linux-tpm453-stable
	pkgdesc = The Hardware-specific CachyOS stable kernel for Acer TMP453-M class hardware kernel and modules
	depends = coreutils
	depends = kmod
	depends = initramfs
	optdepends = wireless-regdb: to set the correct wireless channels of your country
	optdepends = linux-firmware: firmware images needed for some devices
	optdepends = modprobed-db: Keeps track of EVERY kernel module that has ever been probed - useful for those of us who make localmodconfig
	optdepends = scx-scheds: to use sched-ext schedulers
	provides = VIRTUALBOX-GUEST-MODULES
	provides = WIREGUARD-MODULE
	provides = KSMBD-MODULE
	provides = V4L2LOOPBACK-MODULE
	provides = NTSYNC-MODULE
	provides = VHBA-MODULE
	provides = ADIOS-MODULE
	provides = linux-cachyos-lto=7.0.1.r20260421.g2a5a214aa4d-1
	replaces = linux-cachyos-lto

pkgname = linux-tpm453-stable-headers
	pkgdesc = Headers and scripts for building modules for the Hardware-specific CachyOS stable kernel for Acer TMP453-M class hardware kernel
	depends = binutils
	depends = glibc
	depends = libelf
	depends = libgcc
	depends = openssl
	depends = pahole
	depends = xxhash
	depends = zlib
	depends = zstd
	depends = linux-tpm453-stable
	depends = clang
	depends = llvm
	depends = lld
	provides = LINUX-HEADERS
	provides = linux-cachyos-lto-headers=7.0.1.r20260421.g2a5a214aa4d-1
	replaces = linux-cachyos-lto-headers
